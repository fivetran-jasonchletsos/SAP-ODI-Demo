  "engines": [
    {
      "name": "AWS Athena",
      "use_case": "ad-hoc SQL, BI",
      "sample_sql": "SELECT customer_id, SUM(invoice_amount)\nFROM gold.fct_invoices\nGROUP BY 1\nORDER BY 2 DESC LIMIT 10;"
    },
    {
      "name": "DuckDB",
      "use_case": "laptop-local analytics",
      "sample_sql": "INSTALL iceberg; LOAD iceberg;\nSELECT * FROM iceberg_scan('s3://keystone-odi-lake/gold/fct_invoices');"
    },
    {
      "name": "Trino",
      "use_case": "federated multi-source",
      "sample_sql": "SELECT * FROM iceberg.gold.fct_gl_journal\nWHERE posting_year = 2026;"
    },
    {
      "name": "Apache Spark",
      "use_case": "ML feature engineering",
      "sample_sql": "spark.read.format('iceberg').load('gold.fct_invoices').groupBy('customer_id').sum('invoice_amount')"
    },
    {
      "name": "Claude (LLM)",
      "use_case": "agentic Q&A \u2014 no SAP RFC",
      "sample_sql": "Agent queries the parquet directly via the Iceberg catalog.\nNo SAP API call. No analytical SKU. No policy violation."
    }
