sap_odi:
  target: dev
  outputs:
    dev:
      type: athena
      s3_staging_dir: "s3://{{ env_var('LAKE_BUCKET') }}/athena-staging/"
      s3_data_dir: "s3://{{ env_var('LAKE_BUCKET') }}/dbt/"
      region_name: "{{ env_var('AWS_REGION', 'us-east-1') }}"
      database: awsdatacatalog
      schema: keystone_odi
      work_group: "{{ env_var('ATHENA_WORKGROUP', 'keystone-odi') }}"
      threads: 4
